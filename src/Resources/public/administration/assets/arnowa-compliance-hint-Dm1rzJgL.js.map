{% block arnowa_compliance_hint_card %}
<mt-card :title="$tc('arnowa-compliance-hint.card.title')" class="arnowa-compliance-hint-card">

    <mt-switch
        v-model="complianceHint.hintRequired"
        :label="$tc('arnowa-compliance-hint.card.hintRequired')"
    />

    <sw-text-editor
    v-if="isHintRequired"
    :value="complianceHint.hintText"
    :label="$tc('arnowa-compliance-hint.card.hintText')"
    :placeholder="$tc('arnowa-compliance-hint.card.hintTextPlaceholder')"
    :sanitize-input="false"
    @update:value="complianceHint.hintText = $event"
/>

</mt-card>
{% endblock %}
